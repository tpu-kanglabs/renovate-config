{
  "npm": {
    "extends": ["helpers:disableTypesNodeMajor", "packages:eslint"],
    "rangeStrategy": "bump"
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "(^|/)biome\\.json$"
      ],
      "matchStrings": [
        "\"\\$schema\":\\s*\"https://biomejs\\.dev/schemas/(?<currentValue>[^/]+)/schema\\.json\""
      ],
      "depNameTemplate": "@biomejs/biome",
      "datasourceTemplate": "npm"
    }
  ]
}